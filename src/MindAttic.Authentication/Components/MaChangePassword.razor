@namespace MindAttic.Authentication.Components
@using Microsoft.AspNetCore.Components.Forms

@* Presentation only — posts to the authenticated, antiforgery-protected /_ma-auth/change-password endpoint. *@
<form method="post" action="/_ma-auth/change-password" class="ma-auth ma-auth-change">
    <AntiforgeryToken />

    @if (Error)
    {
        <p class="ma-auth-error" role="alert">Couldn't change your password. Check your current password and try again.</p>
    }

    <label class="ma-auth-field">
        <span>Current password</span>
        <input name="currentPassword" type="password" autocomplete="current-password" required />
    </label>
    <label class="ma-auth-field">
        <span>New password</span>
        <input name="newPassword" type="password" autocomplete="new-password" minlength="12" required />
    </label>

    <button type="submit" class="ma-auth-submit">Change password</button>
</form>

@code {
    [Parameter] public bool Error { get; set; }
}
