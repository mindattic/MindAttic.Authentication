@namespace MindAttic.Authentication.Components
@using Microsoft.AspNetCore.Components.Forms

@* Enumeration-safe request — always shows the same "check your email" outcome. Posts to /_ma-auth/reset/request. *@
<form method="post" action="/_ma-auth/reset/request" class="ma-auth ma-auth-forgot">
    <AntiforgeryToken />
    @if (Sent)
    {
        <p class="ma-auth-note" role="status">If an account matches, we've emailed a reset link.</p>
    }
    <label class="ma-auth-field">
        <span>Username or email</span>
        <input name="userNameOrEmail" autocomplete="username" autocapitalize="none" spellcheck="false" required />
    </label>
    <button type="submit" class="ma-auth-submit">Email me a reset link</button>
</form>

@code {
    [Parameter] public bool Sent { get; set; }
}
