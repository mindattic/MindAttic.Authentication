@namespace MindAttic.Authentication.Components
@using Microsoft.AspNetCore.Components.Forms

@* Sets a new password from a reset token. Posts to /_ma-auth/reset/confirm. No auto-login — the user
   signs in fresh afterward (so MFA still applies). *@
<form method="post" action="/_ma-auth/reset/confirm" class="ma-auth ma-auth-reset">
    <AntiforgeryToken />
    <input type="hidden" name="token" value="@Token" />
    @if (Error)
    {
        <p class="ma-auth-error" role="alert">This reset link is invalid or has expired, or the password was rejected.</p>
    }
    <label class="ma-auth-field">
        <span>New password</span>
        <input name="newPassword" type="password" autocomplete="new-password" minlength="12" required />
    </label>
    <button type="submit" class="ma-auth-submit">Set new password</button>
</form>

@code {
    [Parameter] public string? Token { get; set; }
    [Parameter] public bool Error { get; set; }
}
